-- ==============================================
-- FUNCIONES CON TOGGLE
-- ==============================================

local function AutoGlitch()
    task.spawn(function()
        while T.AutoGlitch do
            local r = game.ReplicatedStorage:FindFirstChild("GlitchPower", true)
            if r then r:FireServer(math.huge) end
            wait(0.1)
        end
    end)
end

local function AutoRebirth()
    task.spawn(function()
        while T.AutoRebirth do
            local Power = player.leaderstats:FindFirstChild("Power", true)
            local Btn = player.PlayerGui:FindFirstChild("RebirthButton", true)

            if Power and Btn and Power.Value >= 1e12 then
                if Btn:IsA("TextButton") then
                    fireclickdetector(Btn.ClickDetector)
                else
                    Btn:FireServer()
                end
            end
            wait(0.5)
        end
    end)
end

local function AutoEquipment()
    task.spawn(function()
        while T.AutoEquip do
            local Inv = player:FindFirstChild("Inventory", true)
            local Remote = game.ReplicatedStorage:FindFirstChild("EquipGear", true)

            if Inv and Remote then
                local Best = {}
                for _, g in pairs(Inv:GetChildren()) do
                    local s = g:FindFirstChild("PowerStat", true)
                    if s then table.insert(Best, {g.Name, s.Value}) end
                end
                table.sort(Best, function(a,b) return a[2] > b[2] end)

                for i=1,5 do
                    if Best[i] then
                        Remote:FireServer(Best[i][1])
                        wait(0.2)
                    end
                end
            end
            wait(300)
        end
    end)
end

local function AutoPets()
    task.spawn(function()
        while T.AutoPets do
            local Pets = player:FindFirstChild("Pets", true)
            local Summon = game.ReplicatedStorage:FindFirstChild("SummonPet", true)
            local Equip = game.ReplicatedStorage:FindFirstChild("EquipPet", true)

            if Pets and Summon and Equip then
                for _, p in pairs(Pets:GetChildren()) do
                    Summon:FireServer(p.Name)
                    Equip:FireServer(p.Name)
                    wait(0.3)
                end
            end
            wait(600)
        end
    end)
end

local function AutoDupePets()
    task.spawn(function()
        while T.AutoDupe do
            local Remote = game.ReplicatedStorage:FindFirstChild("DupePet", true)
            if Remote then
                Remote:FireServer("Titan Muscle Pet")
            end
            wait(3)
        end
    end)
end

local function AutoKing()
    task.spawn(function()
        while T.AutoKing do
            local Area = workspace:FindFirstChild("KingArea", true)
            local Claim = game.ReplicatedStorage:FindFirstChild("ClaimKing", true)

            if Area and Claim then
                Claim:FireServer()
            end
            wait(2)
        end
    end)
end

local function AutoFarm()
    task.spawn(function()
        while T.AutoFarm do
            local Attack = game.ReplicatedStorage:FindFirstChild("AttackObject", true)
            if Attack then
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:FindFirstChild("Health") then
                        Attack:FireServer(obj)
                    end
                end
            end
            wait(1)
        end
    end)
end

